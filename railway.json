{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "java -Xms64m -Xmx384m -XX:MaxMetaspaceSize=128m -XX:+UseG1GC -jar target/contab360-0.0.1-SNAPSHOT.jar --spring.profiles.active=prod",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
