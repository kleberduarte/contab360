# Copie para prod.env e preencha ANTES de subir o servidor.
# NUNCA commite prod.env — ele está no .gitignore.

# Banco de dados MySQL
CONTAB360_MYSQL_HOST=localhost
CONTAB360_MYSQL_PORT=3306
CONTAB360_MYSQL_USER=contab360
CONTAB360_MYSQL_PASSWORD=TROQUE_POR_SENHA_FORTE

# Diretórios (devem existir no servidor com permissão de escrita)
CONTAB360_UPLOAD_DIR=/var/contab360/uploads/pendencias
CONTAB360_LOG_DIR=/var/log/contab360

# Perfil Spring ativo
SPRING_PROFILES_ACTIVE=prod
